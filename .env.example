# GA4 OAuth credentials (used by scripts/authenticate.py if client_secret.json doesn't exist)
GA4_CLIENT_ID=
GA4_CLIENT_SECRET=

# GA4 Property ID (required for single-property mode) — numeric only, found in GA4 Admin > Property Settings
GA4_PROPERTY_ID=

# Date range (optional, defaults shown)
GA4_START_DATE=30daysAgo
GA4_END_DATE=today

# Dimensions and metrics (optional, comma-separated)
GA4_DIMENSIONS=country,city
GA4_METRICS=activeUsers,sessions

# File paths (optional, defaults shown)
GA4_TOKEN_PATH=/app/credentials/token.json
GA4_OUTPUT_DIR=/app/output

# CSV options (optional)
GA4_OUTPUT_PREFIX=ga4_report
GA4_CSV_DELIMITER=,

# MySQL (Legitrix database via legitrix-internal Docker network)
# Leave DB_HOST empty to skip MySQL writes (CSV-only mode)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_DATABASE=
